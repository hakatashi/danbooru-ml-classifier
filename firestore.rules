rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access only to hakatasiloving@gmail.com
    match /images/{imageId} {
      allow read: if request.auth != null && request.auth.token.email == 'hakatasiloving@gmail.com';
      allow write: if false;
    }

    // Dedicated favorites collection — one document per image, keyed by image ID
    match /favorites/{imageId} {
      allow read: if request.auth != null && request.auth.token.email == 'hakatasiloving@gmail.com';
      allow create, update: if request.auth != null
        && request.auth.token.email == 'hakatasiloving@gmail.com'
        && isValidFavorites(request.resource.data);
      allow delete: if request.auth != null && request.auth.token.email == 'hakatasiloving@gmail.com';
    }

    // Validate the favorites document structure
    function isValidFavorites(data) {
      return data.keys().hasAll(['isFavorited', 'categories'])
        && data.isFavorited is bool
        && data.categories is list
        && data.categories.size() <= 50
        && (data.categories.size() == 0 || data.categories[0] is string)
        && (data.categories.size() > 0) == data.isFavorited;
    }

    // Allow read access to moderationStats for authenticated users
    match /moderationStats/{document=**} {
      allow read: if request.auth != null && request.auth.token.email == 'hakatasiloving@gmail.com';
      allow write: if false;
    }

    // Allow read access to generated_novels for authenticated user
    match /generated_novels/{novelId} {
      allow read: if request.auth != null && request.auth.token.email == 'hakatasiloving@gmail.com';
      allow create, update, delete: if false;
    }

    // Default: deny all access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}